{
  "schema_version": 1,
  "module": {
    "name": "ibm-roks-cert-manager",
    "path": "ibm/roks/cert-manager",
    "version": "2.3.0-ehf-2-3.2598.3-0.0.17",
    "category": "k8s",
    "description": "Install cert-manager before FLO and BNK custom resources.",
    "provider": "ibm",
    "supported_platforms": ["ibm"],
    "tags": ["ibm", "roks", "cert-manager", "kubernetes"]
  },
  "deployment_pack": {
    "engine": "opentofu",
    "runner_profile": "opentofu-default",
    "working_directory": ".",
    "entrypoints": {
      "module_root": "."
    },
    "lifecycle": {
      "supports_init": true,
      "supports_plan": true,
      "supports_apply": true,
      "supports_destroy": true,
      "supports_refresh": true,
      "supports_drift": true
    }
  },
  "dependencies": {
    "required": [
      { "module": "ibm/roks/cluster" }
    ],
    "optional": []
  },
  "inputs": {
    "required": [],
    "optional": [
      { "name": "enabled", "type": "bool", "default": true },
      { "name": "namespace", "type": "string", "default": "cert-manager" },
      { "name": "chart_version", "type": "string", "default": "v1.17.3" },
      { "name": "chart_repository", "type": "string", "default": "https://charts.jetstack.io" },
      { "name": "wait_for_deployment", "type": "bool", "default": true },
      { "name": "timeout", "type": "number", "default": 300 },
      { "name": "post_deployment_delay", "type": "number", "default": 30 }
    ]
  },
  "outputs": {
    "key_outputs": [
      { "name": "namespace" },
      { "name": "release_name" },
      { "name": "crd_ready" }
    ]
  },
  "credentials": {
    "required": [],
    "optional": []
  }
