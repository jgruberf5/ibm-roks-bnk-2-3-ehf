{
  "schema_version": 1,
  "blueprint": {
    "id": "bigip-next-roks-2.3.0-ehf",
    "version": "2.3.0-ehf-2-3.2598.3-0.0.17",
    "name": "BIG-IP Next for Kubernetes on IBM ROKS Single NIC",
    "description": "Sequential IBM ROKS BNK deployment composed from cluster, cert-manager, FLO, CNEInstance, and license modules.",
    "provider": "IBM",
    "category": "bnk",
    "tags": ["ibm", "roks", "openshift", "bnk", "f5", "infrastructure"]
  },
  "modules": [
    {
      "key": "cluster",
      "module_path": "ibm/roks/cluster",
      "version": "2.3.0-ehf-2-3.2598.3-0.0.17",
      "required": true,
      "path_in_project": "ibm-roks/cluster",
      "depends_on": [],
      "variable_overrides": {}
    },
    {
      "key": "cert_manager",
      "module_path": "ibm/roks/cert-manager",
      "version": "2.3.0-ehf-2-3.2598.3-0.0.17",
      "required": true,
      "path_in_project": "ibm-roks/cert-manager",
      "depends_on": ["cluster"],
      "variable_overrides": {
        "enabled": true,
        "namespace": "cert-manager",
        "chart_version": "v1.17.3"
      }
    },
    {
      "key": "flo",
      "module_path": "ibm/roks/flo",
      "version": "2.3.0-ehf-2-3.2598.3-0.0.17",
      "required": true,
      "path_in_project": "ibm-roks/flo",
      "depends_on": ["cert_manager", "cluster"],
      "variable_overrides": {
        "enabled": true,
        "far_repo_url": "repo.f5.com",
        "flo_namespace": "f5-bnk",
        "utils_namespace": "f5-utils",
        "cert_manager_namespace": "cert-manager",
        "f5_bigip_k8s_manifest_version": "2.3.0-bnpp-ehf-2-3.2598.3-0.0.17",
        "use_cos_bucket": true,
        "ibmcloud_cos_bucket_region": "us-south",
        "ibmcloud_cos_instance_name": "bnk-orchestration",
        "ibmcloud_resources_cos_bucket": "bnk-schematics-resources",
        "f5_cne_far_auth_file": "f5-far-auth-key.tgz",
        "f5_cne_subscription_jwt_file": "trial.jwt"
      },
      "variable_mappings": [
        {
          "from_module": "cert_manager",
          "output": "crd_ready",
          "to_input": "cert_manager_crd_ready"
        },
        {
          "from_module": "cluster",
          "output": "openshift_cluster_name",
          "to_input": "openshift_cluster_name"
        },
        {
          "from_module": "cluster",
          "output": "openshift_cluster_crn",
          "to_input": "openshift_cluster_crn"
        },
        {
          "from_module": "cluster",
          "output": "cluster_vpc_id",
          "to_input": "cluster_vpc_id"
        }
      ]
    },
    {
      "key": "cneinstance",
      "module_path": "ibm/roks/cneinstance",
      "version": "2.3.0-ehf-2-3.2598.3-0.0.17",
      "required": true,
      "path_in_project": "ibm-roks/cneinstance",
      "depends_on": ["flo"],
      "variable_overrides": {
        "enabled": true,
        "flo_namespace": "f5-bnk",
        "utils_namespace": "f5-utils",
        "f5_bigip_k8s_manifest_version": "2.3.0-bnpp-ehf-2-3.2598.3-0.0.17",
        "cneinstance_gateway_api": true,
        "cneinstance_whole_cluster": true,
        "cneinstance_logging_subsystem": true,
        "cneinstance_metric_subsystem": true,
        "cneinstance_deployment_size": "Small",
        "cneinstance_dynamic_routing": false,
        "cneinstance_firewall_acl": true,
        "cneinstance_pseudocni": true,
        "cneinstance_env_discovery": false,
        "cneinstance_cloud_env": true,
        "cneinstance_cloud_provider": "ibm"
      },
      "variable_mappings": [
        {
          "from_module": "flo",
          "output": "trusted_profile_id",
          "to_input": "cneinstance_ibm_trusted_profile_id"
        },
        {
          "from_module": "flo",
          "output": "cluster_issuer_name",
          "to_input": "cluster_issuer_name"
        },
        {
          "from_module": "flo",
          "output": "cneinstance_network_attachments",
          "to_input": "cneinstance_network_attachments"
        },
        {
          "from_module": "cluster",
          "output": "cluster_vpc_name",
          "to_input": "cneinstance_vpc_name"
        }
      ]
    },
    {
      "key": "license",
      "module_path": "ibm/roks/license",
      "version": "2.3.0-ehf-2-3.2598.3-0.0.17",
      "required": true,
      "path_in_project": "ibm-roks/license",
      "depends_on": ["cneinstance"],
      "variable_overrides": {
        "enabled": true,
        "utils_namespace": "f5-utils",
        "license_mode": "connected"
      },
      "variable_mappings": [
        {
          "from_module": "flo",
          "output": "cos_jwt_token",
          "to_input": "jwt_token"
        }
      ]
    }
  ]
}
